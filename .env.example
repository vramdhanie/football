# Free API key from https://www.football-data.org/client/register
# Used only by scripts/fetch-data.mjs (build time) — never shipped to the browser.
FOOTBALL_DATA_TOKEN=your-token-here

# Optional: free API key from https://dashboard.api-football.com/register
# (100 requests/day). Enables real squad data on the team pages, which
# football-data.org only offers as a paid add-on.
# API_FOOTBALL_KEY=your-key-here
